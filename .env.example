# ============================================================================
# Modutecture Spine — environment template  (.env.example)
# Copy to ".env", then set values in THAT file only. .env is git-ignored.
# Secret keys are listed as bare NAMES (no value) so nothing secret can be
# committed from this template. Read programmatically via load_dotenv +
# os.environ.get in agentic-graph/propose_service.py.
#
# The default Ollama brain and the whole twin run fully local with NO keys.
# Cloud keys are ONLY needed for Agent:Mode=langgraph (the propose seam).
# ============================================================================

# ---- Secret keys — set these in .env only (names listed, values intentionally blank)
# Planner pod (cloud OpenAI). If unset, the propose seam degrades to deterministic.
OPENAI_API_KEY=
# Reviewer pod (cloud Anthropic). Optional for the single propose seam.
ANTHROPIC_API_KEY=

# ---- Non-secret tunables (safe to keep in the template) ----------------------
MODU_PLANNER_MODEL=gpt-4o
MODU_REVIEWER_MODEL=claude-sonnet-4-20250514
MODU_LLM_TIMEOUT_S=60

# ---- Local infra (no secrets; defaults already live in appsettings + run.ps1) -
# Uncomment in .env only to override a default.
# ConnectionStrings__Twin=Host=localhost;Port=5431;Database=modutecture;Username=jeethhypno_user;Password=
# Neo4j__Uri=bolt://localhost:7687
# Neo4j__User=neo4j
# Ollama__Url=http://localhost:11434
# Ollama__Model=mistral-nemo

# ============================================================================
# Keys live ONLY in .env on disk, read at runtime via load_dotenv. Never paste
# real key values into chats, commits, screenshots, or tickets. Rotate any key
# that is ever exposed.
# ============================================================================
